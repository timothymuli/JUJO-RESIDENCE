PORT=3000
SESSION_SECRET=replace-with-long-random-string
ADMIN_PASSWORD=changeme123
CONTACT_PHONE=
CONTACT_EMAIL=

# M-Pesa paybill (Lipa na M-Pesa → Paybill)
JUJO_MPESA_PAYBILL=222111
JUJO_MPESA_ACCOUNT=2319887
BLESSED_MPESA_PAYBILL=247247
BLESSED_MPESA_ACCOUNT=749748

# M-Pesa Daraja (STK push + auto-detect Paybill payments)
# MPESA_MOCK=1 → demo STK (no Safaricom account needed)
MPESA_MOCK=1
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
# Optional — defaults to PUBLIC_BASE_URL or RENDER_EXTERNAL_URL + /api/mpesa/stk-callback
MPESA_STK_CALLBACK_URL=
PUBLIC_BASE_URL=

# Staff demo password (landlord + caretakers seeded on first run)
STAFF_PASSWORD=staff123

# Comma-separated emails that receive full access flags (never expose publicly in UI)
SUPERADMIN_EMAILS=admin@jujo.local

# Caretaker mobiles for pending-registration SMS nudges (E.164 or 07…)
CARETAKER_SMS_MLOLONGO=+254745909444,+254727731996
CARETAKER_SMS_SYOKIMAU=+254723161584,+254785562411

# Reminder timezone (Kenya)
REMINDER_TZ=Africa/Nairobi
# Set to 1 to disable scheduled SMS jobs
DISABLE_REMINDERS=0

# Registration: SMS OTP (Africa's Talking — Kenya)
# Local dev: SMS_MOCK=1 logs OTP to server console and returns devOtp in API response
SMS_MOCK=1
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER=

# OTP hashing salt (any long random string)
OTP_SALT=change-this-random-string

# Set to 1 so new sign-ups can log in immediately without admin approval
REGISTRATION_AUTO_APPROVE=0

# Tenant document uploads (ID PDF / lease); default max 12 MB
TENANT_UPLOAD_MAX_BYTES=12582912
